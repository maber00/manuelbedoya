---
import { SEO } from 'astro-seo';
import Footer from '@components/footer.astro';
import Navbar from '@components/navbar/navbar.astro';

// IMPORTANTE: Importación de estilos globales
import '../styles/global.css';

// Importación de fuentes
import '@fontsource/poppins/300.css';
import '@fontsource/poppins/400.css';
import '@fontsource/poppins/500.css';
import '@fontsource/poppins/600.css';
import '@fontsource/poppins/700.css';
import "@fontsource/noto-serif/300.css";
import '@fontsource/noto-serif/400.css';
import '@fontsource/noto-serif/700.css';
import '@fontsource/roboto/400.css';
import '@fontsource/roboto/300.css';
import "@fontsource/noto-serif";
import "@fontsource/permanent-marker";
import "@fontsource/bebas-neue";
import "@fontsource/bebas-neue/400.css";
import "@fontsource/libre-baskerville/400.css";
import "@fontsource/libre-baskerville/700.css";

// Logo Mr Hide (ajusta la ruta/archivo)
import { Image } from 'astro:assets';
import logoImage from '../assets/logo-mrHide.webp';

export interface Props {
  title: string;
}

// Configuración para SEO y Open Graph
const { title } = Astro.props;

// ✅ Marca
const brandName = 'Manuel Bedoya';

// ✅ Dominio (cámbialo por el real cuando lo tengas)
const siteFallback = 'https://manuelbedoya.vercel.app';

// ✅ Título + canonical
const pageTitle = title ? `${title} | ${brandName}` : brandName;
const canonicalURL = new URL(Astro.url.pathname, Astro.site || siteFallback).toString();

// ✅ Metadata social (ajusta handles reales)
const twitterCreator = '@mrHide';
const twitterSite = '@mrHide';

// ✅ OG Image (asegúrate que exista en /public)
const ogImageURL = new URL('/og-mrHide.jpg', Astro.site || siteFallback).toString();
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    
    <!-- Favicons (ajusta los archivos en /public) -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" type="image/x-icon" href="/favicon.ico" />
    
    <meta name="generator" content={Astro.generator} />

    <SEO
      title={pageTitle}
      description="Realización audiovisual con procesos y automatización: video, podcast, animación y contenido continuo. Menos fricción. Más obra terminada."
      canonical={canonicalURL}
      twitter={{
        creator: twitterCreator,
        site: twitterSite,
        card: "summary_large_image"
      }}
      openGraph={{
        basic: {
          url: canonicalURL,
          type: "website",
          title: brandName,
          image: ogImageURL
        },
        image: {
          alt: "Mr Hide",
          width: 1200,
          height: 630
        },
      }}
    />

    <!-- Precargar fuentes críticas -->
    <link
      rel="preload"
      href="/fonts/poppins-v20-latin-regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/roboto-v30-latin-regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
  </head>

  <body>
    <Navbar />
    <slot />
    
  </body>
</html>
