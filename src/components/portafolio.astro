    categoryLabel: "Video",
    videoUrl: "https://www.youtube.com/watch?v=mOV6Hawz2kw"
  },
  {
    id: 10,
    thumbnail: iaThumb1,
    title: "Exploración IA 01",
    category: "ai-explorations",
    categoryLabel: lang === 'es' ? "Dirección Creativa con IA" : "AI Creative Direction",
