        filters: [
          { id: 'all', label: 'Todo' },
          { id: 'commercials', label: 'Comerciales' },
          { id: 'video', label: 'Video' },
          { id: 'ai-explorations', label: 'Dirección Creativa con IA' },
        ],
        viewProject: 'Ver proyecto',
        closeModal: 'Cerrar modal',
        invalidVideo: 'El link del video no es válido. Revisa la URL de YouTube o Vimeo.',
      }
    : {
        title: "Portfolio",
        intro: "This portfolio brings together part of the work I have developed across audiovisual production, post-production, visual direction and creative exploration with AI. It includes commercial pieces, directing work, visual processes and recent explorations where artificial intelligence expands narrative, technical and aesthetic possibilities.",
        filters: [
          { id: 'all', label: 'All' },
          { id: 'commercials', label: 'Commercials' },
          { id: 'video', label: 'Video' },
          { id: 'ai-explorations', label: 'AI Creative Direction' },
        ],
        viewProject: 'View project',
        closeModal: 'Close modal',
        invalidVideo: 'The video link is not valid. Please check the YouTube or Vimeo URL.',
      };

const projects = [
  {
    id: 1,
    thumbnail: aceiteGourmet,
    title: "Comercial Aceite Gourmet - Alianza Team",
    category: "commercials",
    categoryLabel: lang === 'es' ? "Comerciales" : "Commercials",
    videoUrl: "https://www.youtube.com/watch?v=sTFBwbuUmOU"
  },
  {
    id: 2,
    thumbnail: boniceRotoscopia,
    title: "ROTOSCOPIA – BONICE",
    category: "commercials",
    categoryLabel: lang === 'es' ? "Comerciales" : "Commercials",
    videoUrl: "https://www.youtube.com/watch?v=70fK2Odcw0A"
  },
  {
    id: 3,
    thumbnail: fondoLukafe,
    title: "Comercial Lukafe - Casa Luker",
    category: "commercials",
    categoryLabel: lang === 'es' ? "Comerciales" : "Commercials",
    videoUrl: "https://www.youtube.com/watch?v=qTGbghkJBQM"
  },
  {
    id: 4,
    thumbnail: fondoBioexpert,
    title: "Comercial Bioexpert Promo - Motion Graphics",
    category: "commercials",
    categoryLabel: lang === 'es' ? "Comerciales" : "Commercials",
    videoUrl: "https://www.youtube.com/watch?v=ICE1dRRTCoc"
  },
  {
    id: 5,
    thumbnail: reelVideo,
    title: "Video Corporativo Render Producción Audiovisual",
    category: "video",
    categoryLabel: "Video",
    videoUrl: "https://www.youtube.com/watch?v=2w-ODG_VRsI"
  },
  {
    id: 6,
    thumbnail: fondoReelMotion,
    title: "Reel Motion Graphics - Render Producción Audiovisual",
    category: "video",
    categoryLabel: "Video",
    videoUrl: "https://www.youtube.com/watch?v=1NThrbQxYlc"
  },
  {
    id: 7,
    thumbnail: tomasAereas,
    title: "Tomas aéreas Colombia y Ecuador",
