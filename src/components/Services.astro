---
// Importa el componente Image
import { Image } from 'astro:assets';

// Importa tus imágenes
import videoImage from '../assets/portafolio/Video-400x400.jpg';
import comercialesImage from '../assets/portafolio/Comerciales-400x400.jpg';
import fotografiaImage from '../assets/portafolio/Fotografia-400x400.jpg';
---

---
// Importa el componente Image
import { Image } from 'astro:assets';

// Importa tus imágenes
import videoImage from '../assets/portafolio/Video-400x400.jpg';
import comercialesImage from '../assets/portafolio/Comerciales-400x400.jpg';
---

<section id="servicios" class="py-20 bg-black text-white">
  <div class="container mx-auto px-4">
    <div class="text-center mb-16">
      <h2 class="text-4xl font-serif sm:text-7xl font-normal mb-6">
        Nuestros Servicios
      </h2>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-6 max-w-6xl mx-auto">
      <div class="service-block rounded-lg overflow-hidden">
        <a href="/servicios/video" class="block group">
          <div class="relative overflow-hidden">
            <div class="aspect-[4/3] overflow-hidden">
              <Image
                src={videoImage}
                alt="Producción de Video"
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                width={400}
                height={400}
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/90 to-transparent opacity-90"></div>
            </div>

            <div class="absolute bottom-0 left-0 right-0 p-6">
              <span class="bg-[#B1293E] text-white text-xs px-3 py-1 rounded-full">Mr Hide</span>
            </div>
          </div>

          <div class="px-6 py-4">
            <div class="flex items-center text-[#B1293E] font-medium group-hover:underline">
              <span>Conocer más</span>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
              </svg>
            </div>
            <h3 class="text-4xl font-bold text-white group-hover:text-[#B1293E] transition-colors">
              Producción de video
            </h3>
          </div>
        </a>
      </div>

      <div class="service-block rounded-lg overflow-hidden">
        <a href="/servicios/comerciales" class="block group">
          <div class="relative overflow-hidden">
            <div class="aspect-[4/3] overflow-hidden">
              <Image
                src={comercialesImage}
                alt="Comerciales"
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                width={400}
                height={400}
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/90 to-transparent opacity-90"></div>
            </div>

            <div class="absolute bottom-0 left-0 right-0 p-6">
              <span class="bg-[#B1293E] text-white text-xs px-3 py-1 rounded-full">Mr Hide</span>
            </div>
          </div>

          <div class="px-6 py-4">
            <div class="flex items-center text-[#B1293E] font-medium group-hover:underline">
              <span>Conocer más</span>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
              </svg>
            </div>
            <h3 class="text-4xl font-bold text-white group-hover:text-[#B1293E] transition-colors">
              Comerciales
            </h3>
          </div>
        </a>
      </div>
    </div>

    <div class="text-center mt-16">
      <p class="text-lg sm:text-3xl max-w-5xl mx-auto leading-relaxed">
        Diseñamos procesos para convertir una idea en piezas claras, consistentes y listas para usarse.
        Menos fricción. Más obra terminada.
      </p>
    </div>
  </div>
</section>

<style>
  .service-block {
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .service-block:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.25);
  }
</style>