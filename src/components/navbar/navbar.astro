---
import Container from "../container.astro";
import { Astronav, MenuItems, MenuIcon } from "astro-navbar";

export interface Props {
  lang?: 'en' | 'es';
}

const { lang = 'en' } = Astro.props;

const isSpanish = lang === 'es';

const menuitems = isSpanish
  ? [
      { title: "INICIO", path: "/es/#inicio" },
      { title: "SOBRE MÍ", path: "/es/#perfiles" },
      { title: "LO QUE HAGO", path: "/es/#por-que" },
      { title: "PORTAFOLIO", path: "/es/#portafolio" },
      { title: "CONTACTO", path: "/es/#contacto" },
    ]
  : [
      { title: "HOME", path: "/#inicio" },
      { title: "ABOUT", path: "/#perfiles" },
      { title: "WHAT I DO", path: "/#por-que" },
      { title: "PORTFOLIO", path: "/#portafolio" },
      { title: "CONTACT", path: "/#contacto" },
    ];

const switchHref = isSpanish ? "/" : "/es/";
const switchLabel = isSpanish ? "Switch to English" : "Cambiar a español";
const switchText = isSpanish ? "EN" : "ES";
const switchFlag = isSpanish ? "🇬🇧" : "🇪🇸";
---

<Container>
  <header
    id="header"
    class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-transparent transform translate-y-0"
  >
    <div class="flex flex-col lg:flex-row justify-between items-center py-3 px-4 max-w-7xl mx-auto">
      <div class="flex w-full lg:w-auto items-center justify-between mb-4 lg:mb-0">
        <div class="block lg:hidden">
          <MenuIcon class="w-4 h-4 menu-icon text-white" />
        </div>
      </div>

      <Astronav>
        <MenuItems class="hidden w-full lg:w-auto mt-2 lg:flex lg:mt-0">
          <div class="flex flex-col lg:flex-row lg:items-center lg:gap-3">
            <ul class="flex flex-col lg:flex-row lg:gap-3">
              {menuitems.map((item) => (
                <li>
                  <a
                    href={item.path}
                    class="flex px-3 py-2 items-center text-white hover:text-gray-300 transition-colors nav-link"
                  >
                    <span>{item.title}</span>
                  </a>
                </li>
              ))}
            </ul>

            <a
              href={switchHref}
              aria-label={switchLabel}
              class="ml-0 lg:ml-3 mt-2 lg:mt-0 inline-flex items-center justify-center gap-2 rounded-full border border-white/20 px-3 py-2 text-sm text-white transition hover:border-[#f6ad1e] hover:text-[#f6ad1e]"
            >
              <span aria-hidden="true">{switchFlag}</span>
              <span>{switchText}</span>
            </a>
          </div>
        </MenuItems>
      </Astronav>
    </div>
  </header>
</Container>

<style>
  :global(.menu-icon) {
    transition: color 0.3s ease;
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const header = document.querySelector("#header");
    const navLinks = document.querySelectorAll(".nav-link");
    const menuIcon = document.querySelector(".menu-icon");
    let lastScroll = 0;

    function setTopState() {
      header?.classList.remove("bg-black", "shadow-md", "-translate-y-full", "header-scrolled");
      header?.classList.add("bg-transparent", "translate-y-0");

      menuIcon?.classList.add("text-white");
      menuIcon?.classList.remove("text-black");

      navLinks.forEach((link) => {
        link.classList.add("text-white", "hover:text-gray-300");
        link.classList.remove("text-gray-600", "hover:text-gray-900");
      });
    }

    function setScrolledUpState() {
      header?.classList.remove("-translate-y-full", "bg-transparent");
      header?.classList.add("translate-y-0", "bg-black", "shadow-md", "header-scrolled");

      menuIcon?.classList.add("text-white");
      menuIcon?.classList.remove("text-black");

      navLinks.forEach((link) => {
        link.classList.add("text-white", "hover:text-gray-300");
        link.classList.remove("text-gray-600", "hover:text-gray-900");
      });
    }

    function handleScroll() {
      const currentScroll = window.pageYOffset;

      if (currentScroll <= 0) {
        setTopState();
      } else if (currentScroll > lastScroll) {
        header?.classList.add("-translate-y-full");
        header?.classList.remove("translate-y-0");
      } else {
        setScrolledUpState();
      }

      lastScroll = currentScroll;
    }

    let rafId = 0;
    window.addEventListener("scroll", () => {
      if (rafId) cancelAnimationFrame(rafId);
      rafId = requestAnimationFrame(handleScroll);
    });

    handleScroll();
  });
</script>