---
import Container from "../container.astro";
import { Astronav, MenuItems, MenuIcon } from "astro-navbar";

import logoWhite from "../../assets/mrHyde.svg";
import logoDark from "../../assets/mrHyde.svg"; // ✅ si no tienes versión dark, usa la misma. Cambia por otro archivo si existe.

// Menú actualizado (ajusta anchors según tus IDs reales)
const menuitems = [
  { title: "INICIO", path: "/" },
  { title: "QUIÉN SOY", path: "/#por-que" },      // ✅ antes estaba /#por-que-render
  { title: "LO QUE HAGO", path: "/#servicios" },
  { title: "PORTAFOLIO", path: "/#portafolio" },
  { title: "CONTACTO", path: "/contacto" },
];
---

<Container>
  <header
    id="header"
    class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-transparent transform translate-y-0"
  >
    <div class="flex flex-col lg:flex-row justify-between items-center py-3 px-4 max-w-7xl mx-auto">
      <div class="flex w-full lg:w-auto items-center justify-between mb-4 lg:mb-0">
        

        <div class="block lg:hidden">
          <MenuIcon class="w-4 h-4 menu-icon text-white" />
        </div>
      </div>

      <Astronav>
        <MenuItems class="hidden w-full lg:w-auto mt-2 lg:flex lg:mt-0">
          <ul class="flex flex-col lg:flex-row lg:gap-3">
            {menuitems.map((item) => (
              <li>
                <a
                  href={item.path}
                  class="flex px-3 py-2 items-center text-white hover:text-gray-300 transition-colors nav-link"
                >
                  <span>{item.title}</span>
                </a>
              </li>
            ))}
          </ul>
        </MenuItems>
      </Astronav>
    </div>
  </header>
</Container>

<style>
  :global(.menu-icon) {
    transition: color 0.3s ease;
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const header = document.querySelector("#header");
    const logoWhiteEl = document.querySelector("#logo-white");
    const logoDarkEl = document.querySelector("#logo-dark");
    const navLinks = document.querySelectorAll(".nav-link");
    const menuIcon = document.querySelector(".menu-icon");
    let lastScroll = 0;

    function setTopState() {
      header?.classList.remove("bg-black", "shadow-md", "-translate-y-full", "header-scrolled");
      header?.classList.add("bg-transparent", "translate-y-0");

      // Mantén logo blanco (si quieres alternar, descomenta abajo)
      logoWhiteEl?.classList.remove("hidden");
      logoDarkEl?.classList.add("hidden");

      menuIcon?.classList.add("text-white");
      menuIcon?.classList.remove("text-black");

      navLinks.forEach((link) => {
        link.classList.add("text-white", "hover:text-gray-300");
        link.classList.remove("text-gray-600", "hover:text-gray-900");
      });
    }

    function setScrolledUpState() {
      header?.classList.remove("-translate-y-full", "bg-transparent");
      header?.classList.add("translate-y-0", "bg-black", "shadow-md", "header-scrolled");

      // En fondo negro, logo blanco funciona perfecto
      logoWhiteEl?.classList.remove("hidden");
      logoDarkEl?.classList.add("hidden");

      menuIcon?.classList.add("text-white");
      menuIcon?.classList.remove("text-black");

      navLinks.forEach((link) => {
        link.classList.add("text-white", "hover:text-gray-300");
        link.classList.remove("text-gray-600", "hover:text-gray-900");
      });
    }

    function handleScroll() {
      const currentScroll = window.pageYOffset;

      if (currentScroll <= 0) {
        setTopState();
      } else if (currentScroll > lastScroll) {
        // bajando
        header?.classList.add("-translate-y-full");
        header?.classList.remove("translate-y-0");
      } else {
        // subiendo
        setScrolledUpState();
      }

      lastScroll = currentScroll;
    }

    let rafId = 0;
    window.addEventListener("scroll", () => {
      if (rafId) cancelAnimationFrame(rafId);
      rafId = requestAnimationFrame(handleScroll);
    });

    handleScroll();
  });
</script>
