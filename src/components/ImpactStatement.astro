<section class="bg-black text-white py-24">
  <div class="container mx-auto px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center max-w-7xl mx-auto">

      <!-- MÁSCARA (IZQUIERDA EN DESKTOP) -->
      <div class="relative w-full aspect-square max-w-md mx-auto order-2 lg:order-1">
        <!-- Este es el "molde" que gira -->
        <div
          id="maskShell"
          class="mask-shell w-full h-full will-change-transform"
        >
          <!-- El video se contra-rota para verse fijo -->
          <video
            id="maskVideo"
            class="mask-video w-full h-full object-cover"
            src="/money.mp4"
            autoplay
            muted
            loop
            playsinline
            preload="auto"
          ></video>
        </div>
      </div>

      <!-- TEXTO (DERECHA EN DESKTOP) -->
      <div class="space-y-8 order-1 lg:order-2">
        <p
          class="text-3xl sm:text-4xl md:text-7xl text-[#f6ad1e]"
    style="font-family: 'Libre Baskerville', 'Baskerville', serif;"
        >
La mayoría de las decisiones se toman antes de que podamos nombrarlas.
        </p>

        <p class="text-base sm:text-2xl md:text-3xl text-white max-w-xl">
Los clics, likes y reproducciones muestran alcance; el verdadero valor está en lo que una pieza logra provocar y dejar en la mente de quien la ve.
        </p>

        <p class="text-lg sm:text-2xl md:text-3xl max-w-2xl leading-snug">
         Este portafolio reúne trabajo audiovisual creado para captar atención, generar emoción y permanecer en la memoria.
        </p>
      </div>

    </div>
  </div>
</section>

<style>
  /* El “molde” que se enmascara y gira */
  .mask-shell {
    width: 100%;
    height: 100%;
    transform-origin: center center;

    /* MÁSCARA aplicada al SHELL (no al video) */
    -webkit-mask-image: url("/logoMrHyde.svg");
    mask-image: url("/logoMrHyde.svg");

    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;

    -webkit-mask-position: center;
    mask-position: center;

    -webkit-mask-size: contain;
    mask-size: contain;

    background: #000;
    overflow: hidden;
  }

  /* El video dentro del shell */
  .mask-video {
    width: 100%;
    height: 100%;
    transform-origin: center center;
    will-change: transform;
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const shell = document.getElementById("maskShell");
  const vid = document.getElementById("maskVideo");

  if (shell && vid) {
    const setVidRotation = gsap.quickSetter(vid, "rotation", "deg");

    gsap.to(shell, {
      rotation: 180, // cambia a 360 si quieres vuelta completa
      ease: "none",
      scrollTrigger: {
        trigger: shell,
        start: "top bottom",
        end: "bottom top",
        scrub: 1.2,
        onUpdate: () => {
          // contra-rotación: el video se ve fijo, la máscara "gira"
          const r = gsap.getProperty(shell, "rotation");
          setVidRotation(-r);
        }
      }
    });
  }
</script>
