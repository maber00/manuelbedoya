---
---
<div class="hero-container relative w-full h-screen overflow-hidden bg-black flex items-end">
  <!-- Video Background -->
  <div class="absolute inset-0 w-full h-full z-0" id="videoWrapper">
    <div class="absolute inset-0 w-full h-full video-container overflow-hidden">
      <iframe
        id="backgroundVideo"
        src="https://player.vimeo.com/video/1163773815?background=1&autoplay=1&loop=1&muted=1&controls=0&title=0&byline=0&portrait=0"
        class="absolute top-1/2 left-1/2 w-[200vw] h-[200vh] -translate-x-1/2 -translate-y-1/2"
        frameborder="0"
        allow="autoplay; fullscreen; picture-in-picture"
        allowfullscreen
      ></iframe>
    </div>
  </div>

  <!-- Overlay negro -->
  <div class="absolute inset-0 bg-black/50 z-10"></div>

  <!-- Contenido -->
  <div class="relative z-20 w-full flex flex-col">
    <div class="pl-6 sm:pl-12 md:pl-16 lg:pl-24 mb-16 md:mb-24">
      <div class="flex flex-col text-white max-w-4xl">
        <p
          class="text-4xl sm:text-2xl md:text-5xl font-bold tracking-tight text-left text-[#f6ad1e]"
          style="font-family: 'Libre Baskerville', 'Baskerville', serif;"
        >
          CONTENIDO AUTÉNTICO
        </p>

        <p
          class="text-4xl sm:text-2xl md:text-7xl lg:text-5xl xl:text-7xl font-bold tracking-tight text-left text-[#f6ad1e]"
          style="font-family: 'Libre Baskerville', 'Baskerville', serif;"
        >
          IMPACTO PODEROSO
        </p>
      </div>
    </div>
  </div>
</div>

<style>
  .hero-container {
    will-change: transform;
  }

  .video-container {
    overflow: hidden;
  }

  /* Móviles */
  @media (max-width: 767px) {
    #backgroundVideo {
      width: 200vw !important;
      height: 200vh !important;
      transform: translate(-50%, -50%) scale(2) !important;
      will-change: transform;
    }
  }

  /* Tablets */
  @media (min-width: 768px) and (max-width: 1024px) {
    #backgroundVideo {
      width: 180vw !important;
      height: 180vh !important;
      transform: translate(-50%, -50%) scale(1.8) !important;
      will-change: transform;
    }
  }

  /* Desktop mediano */
  @media (min-width: 1025px) and (max-width: 1366px) {
    #backgroundVideo {
      width: 150vw !important;
      height: 150vh !important;
      transform: translate(-50%, -50%) scale(1.5) !important;
      will-change: transform;
    }
  }
</style>